MULTILEVEL INHERITANCE
CODE:-
using System;
public class A
{
public void fun1()
{
Console.WriteLine("Class A is here!");
}
}
public class B : A
{
public void fun2()
{
Console.WriteLine("Class B is here!");
}
}
public class C : B
{
public void fun3()
{
Console.WriteLine("Class C is here!");
}
}
public class Program
{
public static void Main(string[] args)
{
C obj = new C();
obj.fun1();
obj.fun2();
obj.fun3();
}

HIERARCHICAL INHERITANCE
CODE:-
using System;
public class A
{
public void fun1()
{
Console.WriteLine("Class A is here!");
}
}
public class B : A
{
public void fun2()
{
Console.WriteLine("Class B is here!");
}
}
public class C : A
{
public void fun3()
{
Console.WriteLine("Class C is here!");
}
}
public class Program
{
public static void Main(string[] args)
{
B obj = new B();
obj.fun1();
obj.fun2();
C obj1 = new C();
obj1.fun1();
obj1.fun3(); // Correct
}
}

MULTIPLE INHERITANCE
CODE:-
using System;
public interface A
{
public void fun1();
}
public interface B
{
public void fun2();
}
public class C: A,B
{
public void fun1()
{
Console.WriteLine("Interface A is here!");
}
public void fun2()
{
Console.WriteLine("Interface B is here!");
}
public void fun3()
{
Console.WriteLine("Class C is here!");
}
}
public class Program
{
public static void Main(string[] args)
{
C obj1 = new C();
obj1.fun1();
obj1.fun2();
obj1.fun3();
} 
}

C] CONSTRUCTOR OVERLOADING
CODE:-
using System;
public class abc {
abc(int num , int num1) {
Console.WriteLine("Addition of 2 num = "
+(num+num1)); 
}
abc(int num , int num1 , int num2) {
Console.WriteLine("Addition of 3 num = "
+(num+num1+num2)); 
}
public static void Main(string[] args) {
abc obj = new abc(11,12);
abc obj1 = new abc(11,12,13); 
}
}

D] INTERFACES
CODE:-
