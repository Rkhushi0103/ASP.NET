A] FUNCTION OVER LOADING
CODE:-
using System;
public class abc
{
void fun1(int num , int num1)
{
Console.WriteLine("Addition of 2 num = " +(num+num1));
}
void fun1(int num , int num1 , int num2)
{
Console.WriteLine("Addition of 3 num = " +(num+num1+num2));
}
public static void Main(string[] args)
{
abc obj = new abc();
obj.fun1(11,12);
obj.fun1(11,12,13);
}
} 

