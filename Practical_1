b)Create an application to print Floyd’s triangle till n rows in C#.
CODE:_
using System;
class Flyod
{
static void Main()
{
int count = 1;
for(int i=0 ; i<5; i++)//row
{
for(int j=0 ; j<=i ;j++)//columns
{
Console.Write(count + "");
count++;
}
Console.WriteLine();
}
Console.WriteLine("Khushi Patel T032");
}
}

